DATABASE_URL=sqlite:///data/paper_odds_lab.sqlite

DEFAULT_SPORT=football
DEFAULT_MARKET=1X2
DEFAULT_STAKE_UNITS=1.0

MIN_EDGE=0.07
MIN_ODDS=1.70
MAX_ODDS=3.50

FEATURE_VERSION=v0_baseline
MODEL_NAME=baseline_heuristic
MODEL_VERSION=v0

ELO_INITIAL_RATING=1500
ELO_K_FACTOR=20
ELO_HOME_ADVANTAGE=65

LOG_LEVEL=INFO
LIVE_COLLECTION_ENABLED=false

AI_ANALYSIS_MODE=deterministic
AI_ANALYSIS_MODEL_NAME=deterministic_ai_fallback

# Dashboard build-time setting for deployed static frontend.
# Leave empty locally to use the Vite /api proxy.
VITE_API_BASE_URL=
