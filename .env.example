DATABASE_URL=sqlite:///data/paper_odds_lab.sqlite

DEFAULT_SPORT=football
DEFAULT_MARKET=1X2
DEFAULT_STAKE_UNITS=1.0

MIN_EDGE=0.07
MIN_ODDS=1.70
MAX_ODDS=3.50

FEATURE_VERSION=v0_baseline
MODEL_NAME=baseline_heuristic
MODEL_VERSION=v0

ELO_INITIAL_RATING=1500
ELO_K_FACTOR=20
ELO_HOME_ADVANTAGE=65

LOG_LEVEL=INFO

# Must be true for run-scheduled-paper-worker.
# Keep false for local/API services that should not collect live data.
LIVE_COLLECTION_ENABLED=false

# Scheduled worker input. WORKER_SNAPSHOT_URL takes precedence when set.
WORKER_PROVIDER=misli-public
WORKER_SNAPSHOT=docs/fixtures/task45-live-dry-run-snapshot.json
# WORKER_SNAPSHOT_URL=https://<api-service>.up.railway.app/api/live/snapshots/latest/misli-public
WORKER_MODEL=baseline_heuristic
WORKER_LEAGUE=railway-fixture
WORKER_SEASON=2026

# Snapshot producer/API ingest.
# Set on the API and producer services. Keep secret in Railway.
SNAPSHOT_INGEST_TOKEN=
SNAPSHOT_SOURCE_URL=https://www.misli.az/idman-novleri/futbol
SNAPSHOT_SPORT=football
SNAPSHOT_POST_URL=https://<api-service>.up.railway.app/api/live/snapshots/latest/misli-public

AI_ANALYSIS_MODE=deterministic
AI_ANALYSIS_MODEL_NAME=deterministic_ai_fallback

# API CORS settings for local and deployed dashboards.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_REGEX=^(http://(localhost|127\.0\.0\.1):\d+|https://[a-z0-9-]+\.up\.railway\.app)$

# Dashboard build-time setting for deployed static frontend.
# Leave empty locally to use the Vite /api proxy.
VITE_API_BASE_URL=
